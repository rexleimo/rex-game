{
  "name": "rex-game",
  "version": "0.3.0",
  "private": true,
  "description": "rex-game — 静态娱乐游戏站（部署 Gitee Pages）。首个游戏：潮汕圣杯占卜。",
  "scripts": {
    "dev": "next dev -p 3030",
    "dev:clean": "rm -rf .next && next dev -p 3030",
    "build": "next build",
    "start": "next start",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "fonts": "bash scripts/fonts-subset.sh",
    "og": "node scripts/generate-og.mjs",
    "og:culture": "node --experimental-strip-types scripts/generate-culture-og.mjs",
    "lint": "next lint",
    "preview": "npm run build && npx serve out -l 3040"
  },
  "dependencies": {
    "@babylonjs/core": "^7.54.0",
    "@babylonjs/havok": "^1.3.13",
    "@babylonjs/loaders": "^7.54.3",
    "@babylonjs/materials": "^7.54.0",
    "@mediapipe/tasks-vision": "^0.10.22",
    "next": "^15.1.6",
    "phaser": "3.90.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "playwright-core": "1.51.1",
    "sharp": "0.34.5",
    "typescript": "^5.7.3"
  }
}
